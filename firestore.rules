rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /pessoas/{pessoaId} {
      allow read, create, update, delete: if request.auth != null;
    }

    match /diagramas/{diagramaId} {
      allow read, create, update, delete: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
